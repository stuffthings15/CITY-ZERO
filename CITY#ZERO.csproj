<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <Nullable>enable</Nullable>
    <UseUwp>true</UseUwp>
    <Platforms>x86;x64;arm64</Platforms>
    <RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
    <DefaultLanguage>en-US</DefaultLanguage>
    <AssemblyName>CITY_ZERO</AssemblyName>
    <RootNamespace>CITY_ZERO</RootNamespace>
    <PublishAot>true</PublishAot>
    <PublishProfile>win-$(Platform).pubxml</PublishProfile>
    <DisableRuntimeMarshalling>true</DisableRuntimeMarshalling>
    <EnableMsixTooling>true</EnableMsixTooling>
  </PropertyGroup>
  <!--
    Inventory for CITY#ZERO (embedded in project file)

    Summary:
    - Project: CITY#ZERO
    - TargetFramework: net10.0-windows10.0.26100.0
    - Platforms: x86, x64, arm64

    Key files and folders:
    - CITY#ZERO.csproj (this file)
    - App.xaml, App.xaml.cs
    - MainPage.xaml, MainPage.xaml.cs
    - Package.appxmanifest
    - Properties/launchSettings.json
    - Properties/PublishProfiles/*.pubxml
    - obj/ (generated files: App.g.cs, MainPage.g.cs, AssemblyInfo)

    Notes:
    - obj/ contains generated build artifacts; do not edit them.
    - To create an external Inventory.md, request a detailed manifest (file hashes, sizes).
  -->

