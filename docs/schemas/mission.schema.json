{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MissionDefinition",
  "type": "object",
  "required": ["mission_id", "title", "archetype", "giver_faction", "objectives", "success_conditions", "failure_conditions", "rewards"],
  "properties": {
    "mission_id": { "type": "string", "pattern": "^mission_[a-z0-9_]+$" },
    "title": { "type": "string" },
    "archetype": {
      "type": "string",
      "enum": ["heist", "assassination", "escort", "extraction", "courier", "sabotage", "surveillance", "ambush", "territory_war", "undercover", "racing", "debt_collection", "riot", "data_breach", "elimination_run"]
    },
    "giver_faction": { "type": "string" },
    "giver_npc_id": { "type": "string" },
    "prerequisites": {
      "type": "object",
      "properties": {
        "faction_rep_min": { "type": "object" },
        "missions_completed": { "type": "array", "items": { "type": "string" } },
        "story_flag": { "type": ["string", "null"] }
      }
    },
    "location": {
      "type": "object",
      "required": ["district"],
      "properties": {
        "district": { "type": "string" },
        "spawn_point": { "type": "string" },
        "area_id": { "type": "string" }
      }
    },
    "time_limit_seconds": { "type": ["integer", "null"], "minimum": 0 },
    "heat_modifier_base": { "type": "number", "minimum": 0 },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "label", "required"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["kill", "reach", "deliver", "protect", "hack", "survive", "interact", "collect", "escort"] },
          "target": { "type": "string" },
          "label": { "type": "string" },
          "required": { "type": "boolean" },
          "bonus_cash": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "success_conditions": { "type": "object" },
    "failure_conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string" },
          "area": { "type": "string" },
          "payload_held": { "type": "boolean" }
        }
      }
    },
    "rewards": {
      "type": "object",
      "required": ["cash"],
      "properties": {
        "cash": { "type": "integer", "minimum": 0 },
        "reputation": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["faction", "delta"],
            "properties": {
              "faction": { "type": "string" },
              "delta": { "type": "integer" }
            }
          }
        },
        "unlock_flags": { "type": "array", "items": { "type": "string" } },
        "items": { "type": "array" }
      }
    }
  }
}
